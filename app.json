{
  "expo": {
    "name": "Digital Ledger",
    "slug": "yasirsales",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "digitalledger",
    "description": "Beyond the books",
    "userInterfaceStyle": "light",
    "newArchEnabled": false,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "com.digitalledger.app",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundColor": "#0EA5E9",
        "backgroundColor": "#082f49"
      },
      "edgeToEdgeEnabled": false,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-sqlite",
        {
          "enableFTS": false
        }
      ],
      "@react-native-community/datetimepicker",
      "./plugins/withRemovedSplashScreen"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "91f6f20e-ff8a-47eb-8052-223f9308f592"
      }
    }
  }
}
